{
  "name": "ato-portal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "generate:api": "bash scripts/sync_openapi.sh && openapi-zod-client openapi/portal.openapi.json -o src/api/generated/portalSchemas.ts --export-schemas || echo 'OpenAPI codegen skipped; portal uses src/api/responseSchemas.ts until spec refs are codegen-safe.'",
    "sync:openapi": "bash scripts/sync_openapi.sh",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:managed": "ATO_E2E_MANAGED_STACK=1 ATO_E2E_STACK_READY=1 playwright test",
    "test:e2e:existing": "ATO_E2E_USE_EXISTING_STACK=1 ATO_E2E_STACK_READY=1 playwright test",
    "test:e2e:ui": "playwright test --ui",
    "install:e2e-browsers": "playwright install chromium",
    "stack:e2e:start": "bash ../scripts/e2e-stack-start.sh --portal",
    "stack:e2e:stop": "bash ../scripts/e2e-stack-stop.sh"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.1.1",
    "openapi-zod-client": "^1.18.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.8"
  }
}
