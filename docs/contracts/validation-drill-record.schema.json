{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ato.local/schemas/validation-drill-record.schema.json",
  "title": "ATO Customer Validation Drill Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "drill_id",
    "drill_version",
    "environment_type",
    "execution_mode",
    "started_at_utc",
    "completed_at_utc",
    "application_digest",
    "config_digest",
    "fixture_digest",
    "operator_identifier",
    "approver_identifier",
    "outcome",
    "hard_stop_claims",
    "results",
    "record_digest"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_id": {
      "$ref": "#/$defs/uuidV4"
    },
    "drill_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9-]{0,126}[a-z0-9]$"
    },
    "drill_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "environment_type": {
      "type": "string",
      "enum": [
        "dev_local",
        "onprem_staging",
        "onprem_production",
        "customer_staging",
        "customer_production"
      ]
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "dry_run",
        "live"
      ]
    },
    "started_at_utc": {
      "$ref": "#/$defs/utcDateTime"
    },
    "completed_at_utc": {
      "$ref": "#/$defs/utcDateTime"
    },
    "application_digest": {
      "$ref": "#/$defs/sha256"
    },
    "config_digest": {
      "$ref": "#/$defs/sha256"
    },
    "fixture_digest": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/sha256"
        }
      ]
    },
    "operator_identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "approver_identifier": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      ]
    },
    "outcome": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "skip",
        "invalid"
      ]
    },
    "hard_stop_claims": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "$ref": "#/$defs/hardStopClaim"
      }
    },
    "results": {
      "$ref": "#/$defs/redactedResults"
    },
    "record_digest": {
      "$ref": "#/$defs/sha256"
    }
  },
  "$defs": {
    "uuidV4": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "utcDateTime": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,6})?Z$"
    },
    "hardStopClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hard_stop_id",
        "claim_status"
      ],
      "properties": {
        "hard_stop_id": {
          "type": "string",
          "pattern": "^HS-[0-9]{3}$"
        },
        "claim_status": {
          "type": "string",
          "enum": [
            "not_claimed",
            "still_open",
            "verified_closed",
            "blocked"
          ]
        },
        "detail": {
          "type": "string",
          "maxLength": 512
        }
      }
    },
    "redactedResults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "checks"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "checks": {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/redactedCheck"
          }
        },
        "detail": {
          "type": "string",
          "maxLength": 4096
        },
        "exit_code": {
          "type": "integer"
        },
        "preflight_status": {
          "type": "string",
          "enum": [
            "ready",
            "skipped_live_required",
            "blocked_destructive",
            "unsupported"
          ]
        }
      }
    },
    "redactedCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "skip",
            "warn"
          ]
        },
        "detail": {
          "type": "string",
          "maxLength": 512
        }
      }
    }
  }
}
