{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ato.local/schemas/normalize-proposal-fact-bundle.schema.json",
  "title": "Normalize Proposal Fact Bundle",
  "$comment": "Canonical bounded user-prompt payload for normalize_proposal v1. Matches FactBundle.prompt_payload serialized by build_user_prompt(). fact_bundle_sha256 is the SHA-256 of stable_json_dumps(prompt_payload). input_digest may differ when reservation canonicalization excludes omitted fields. Protected storage MUST persist exactly this document for model-input bytes. package_revision_id, prompt_version, and response_schema_version are integration-required metadata outside prompt_payload until the core embeds them.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_id",
    "empty_targets",
    "target_catalog",
    "artifacts",
    "omitted_segment_ids",
    "context_complete"
  ],
  "properties": {
    "profile_id": {
      "enum": [
        "fedramp_20x_program",
        "fedramp_rev5_transition",
        "fisma_agency_security"
      ]
    },
    "empty_targets": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "string",
        "pattern": "^(/([^~/]|~[01])*)*$",
        "maxLength": 2000
      }
    },
    "target_catalog": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "$ref": "#/$defs/TargetCatalogEntry"
      }
    },
    "artifacts": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/FactBundleArtifact"
      }
    },
    "omitted_segment_ids": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "string",
        "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}:[1-9][0-9]*$",
        "maxLength": 80
      }
    },
    "context_complete": {
      "type": "boolean"
    }
  },
  "$defs": {
    "TargetCatalogEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pointer",
        "description",
        "value_kind"
      ],
      "properties": {
        "pointer": {
          "type": "string",
          "pattern": "^(/([^~/]|~[01])*)*$",
          "maxLength": 2000
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "value_kind": {
          "enum": [
            "string",
            "nullable_string",
            "enum"
          ]
        },
        "max_length": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65536
        },
        "enum_values": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "value_kind": {
                "const": "enum"
              }
            },
            "required": [
              "value_kind"
            ]
          },
          "then": {
            "required": [
              "enum_values"
            ]
          }
        }
      ]
    },
    "FactBundleArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "sha256",
        "filename",
        "detected_format",
        "segments"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "format": "uuid"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "filename": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 255
            },
            {
              "type": "null"
            }
          ]
        },
        "detected_format": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "segments": {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/FactBundleSegment"
          }
        }
      }
    },
    "FactBundleSegment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "segment_index",
        "text",
        "locator_kind",
        "extraction_method",
        "text_truncated"
      ],
      "properties": {
        "segment_index": {
          "type": "integer",
          "minimum": 1
        },
        "text": {
          "type": "string",
          "maxLength": 4000
        },
        "locator_kind": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            {
              "type": "null"
            }
          ]
        },
        "extraction_method": {
          "enum": [
            "deterministic",
            "text",
            "vision"
          ]
        },
        "text_truncated": {
          "type": "boolean"
        }
      }
    }
  }
}
