{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ato.local/schemas/authority-manifest.schema.json",
  "title": "ATO Authority Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "status",
    "created_at",
    "sources"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "manifest_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "status": {
      "enum": [
        "draft",
        "approved",
        "superseded"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "approved_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "pattern": "Z$"
    },
    "approved_by": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 255
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "approved"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "approved_at",
          "approved_by"
        ],
        "properties": {
          "approved_at": {
            "type": "string",
            "format": "date-time",
            "pattern": "Z$"
          },
          "approved_by": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "pattern": "\\S"
          },
          "sources": {
            "items": {
              "properties": {
                "review_status": {
                  "const": "reviewed"
                }
              },
              "required": [
                "review_status"
              ]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_id",
        "title",
        "source_url",
        "source_version_or_date",
        "retrieved_at_utc",
        "effective_date",
        "sha256",
        "size_bytes",
        "local_path",
        "review_status"
      ],
      "properties": {
        "authority_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "source_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri",
          "maxLength": 2048
        },
        "source_version_or_date": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 255
        },
        "retrieved_at_utc": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "pattern": "Z$"
        },
        "effective_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        },
        "size_bytes": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "local_path": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^reference/[A-Za-z0-9._/-]+$",
          "maxLength": 512
        },
        "review_status": {
          "enum": [
            "pending",
            "reviewed",
            "rejected"
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 2000
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "review_status": {
                "const": "reviewed"
              }
            },
            "required": [
              "review_status"
            ]
          },
          "then": {
            "required": [
              "source_url",
              "source_version_or_date",
              "retrieved_at_utc",
              "effective_date",
              "sha256",
              "size_bytes",
              "local_path"
            ],
            "properties": {
              "source_url": {
                "type": "string",
                "format": "uri"
              },
              "source_version_or_date": {
                "type": "string",
                "minLength": 1,
                "pattern": "\\S"
              },
              "retrieved_at_utc": {
                "type": "string",
                "format": "date-time",
                "pattern": "Z$"
              },
              "effective_date": {
                "type": "string",
                "format": "date"
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "size_bytes": {
                "type": "integer",
                "minimum": 1
              },
              "local_path": {
                "type": "string",
                "pattern": "^reference/[A-Za-z0-9._/-]+$"
              }
            }
          }
        }
      ]
    }
  }
}
