{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ato.local/schemas/content-manifest.schema.json",
  "title": "ATO Package Content Manifest",
  "$comment": "Semantic validation MUST recompute each source artifact SHA-256 and size, verify that each storage_key suffix equals sha256, enforce unique artifact_id and storage_key values, and verify that the package revision content_manifest_sha256 matches the durable manifest bytes. User-supplied filenames are display metadata only and MUST NOT be used as storage paths.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "package_revision_id",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "package_revision_id": {
      "$ref": "#/$defs/uuidV4"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/sourceArtifact"
      }
    }
  },
  "$defs": {
    "uuidV4": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "sourceArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "storage_key",
        "sha256",
        "size_bytes"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/uuidV4"
        },
        "storage_key": {
          "type": "string",
          "pattern": "^[a-f0-9]{2}/[a-f0-9]{64}$",
          "maxLength": 67
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 104857600
        }
      }
    }
  }
}
