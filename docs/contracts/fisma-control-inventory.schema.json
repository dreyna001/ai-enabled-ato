{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ato.local/schemas/fisma-control-inventory.schema.json",
  "title": "ATO FISMA Control Inventory",
  "$comment": "Customer-supplied security control inventory shape for FISMA workflows. Semantic validation MUST reject duplicate control_ids, noncanonical control_ids, privacy-family controls when a clear catalog namespace is available, and approval-field boundary violations. Fixtures are examples only and do not establish production agency inventory rules.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "inventory_id",
    "authority_manifest_id",
    "impact_level",
    "status",
    "approved_at",
    "approved_by",
    "source_reference",
    "control_ids"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "inventory_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$",
      "maxLength": 128
    },
    "authority_manifest_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$",
      "maxLength": 128
    },
    "impact_level": {
      "type": "string",
      "enum": [
        "low",
        "moderate",
        "high"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "approved"
      ]
    },
    "approved_at": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/utcDateTime"
        }
      ]
    },
    "approved_by": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "pattern": "\\S"
        }
      ]
    },
    "source_reference": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "control_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/nistControlId"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "approved"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "approved_at",
          "approved_by"
        ],
        "properties": {
          "approved_at": {
            "$ref": "#/$defs/utcDateTime"
          },
          "approved_by": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "pattern": "\\S"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "draft"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "approved_at": {
            "type": "null"
          },
          "approved_by": {
            "type": "null"
          }
        }
      }
    }
  ],
  "$defs": {
    "utcDateTime": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "nistControlId": {
      "type": "string",
      "pattern": "^[A-Z]{2,3}-\\d+(?:\\([0-9]+\\)|(?:\\.[0-9]+)+)?$"
    }
  }
}
