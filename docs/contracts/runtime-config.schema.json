{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ato.local/schemas/runtime-config.schema.json",
  "title": "ATO Validated Runtime Configuration",
  "description": "Non-secret runtime configuration parsed into JSON-native values before startup validation.",
  "type": "object",
  "additionalProperties": false,
  "$comment": "Startup code must reject secret values in this document, resolve credential references through protected deployment facilities, validate authority manifests, and apply data-routing policy before every model call. JSON Schema cannot verify filesystem ownership/mode, endpoint DNS resolution, egress firewall policy, endpoint qualification, customer approvals, dependency readiness, or cross-field numeric relationships.",
  "required": [
    "schema_version",
    "runtime_profile"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "runtime_profile": {
      "enum": [
        "dev_local",
        "onprem_production"
      ]
    },
    "INSTALLATION_CUSTOMER_ENTERPRISE_ID": {
      "$ref": "#/$defs/boundedIdentifier",
      "$comment": "Single customer enterprise served by this installation. Required for onprem_production; dev_local defaults to dev-local-enterprise when omitted."
    },
    "ALLOW_LOOPBACK_HTTP_INTERNAL_ENDPOINTS": {
      "type": "boolean",
      "default": false,
      "$comment": "Explicit opt-in for HTTP model endpoints that use literal loopback IP addresses (IPv4 127.0.0.0/8 or IPv6 ::1). It does not permit DNS hostnames such as localhost, private-network hosts, or other cleartext endpoints."
    },
    "TEXT_MODEL_PROVIDER": {
      "type": "string",
      "enum": [
        "openai_compatible",
        "aws_bedrock"
      ],
      "default": "openai_compatible",
      "$comment": "Selects the text-model HTTP/API client. OpenAI-compatible uses TEXT_MODEL_ENDPOINT_URL and an API key credential. AWS Bedrock uses AWS_REGION, TEXT_MODEL_NAME as the Bedrock model ID, and the standard AWS credential chain."
    },
    "AWS_REGION": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32,
      "pattern": "^[a-z]{2}(?:-[a-z]+)+-\\d+$",
      "$comment": "Required when TEXT_MODEL_PROVIDER is aws_bedrock. Secrets stay in the AWS credential chain, not in runtime JSON."
    },
    "TEXT_MODEL_ENDPOINT_URL": {
      "$ref": "#/$defs/secureEndpointUrl"
    },
    "TEXT_MODEL_NAME": {
      "$ref": "#/$defs/modelName"
    },
    "TEXT_MODEL_CONTEXT_TOKENS": {
      "$ref": "#/$defs/positiveInteger"
    },
    "TEXT_MODEL_MAX_OUTPUT_TOKENS": {
      "$ref": "#/$defs/positiveInteger"
    },
    "TEXT_MODEL_TIMEOUT_SECONDS": {
      "$ref": "#/$defs/positiveInteger"
    },
    "TEXT_MODEL_MAX_RETRIES": {
      "type": "integer",
      "minimum": 0,
      "default": 2
    },
    "TEXT_MODEL_ENDPOINT_PROFILE": {
      "$ref": "#/$defs/endpointProfile"
    },
    "TEXT_MODEL_CREDENTIAL_REFERENCE": {
      "$ref": "#/$defs/credentialReference"
    },
    "TEXT_MODEL_TEMPERATURE": {
      "type": "number",
      "minimum": 0,
      "maximum": 2,
      "default": 0,
      "$comment": "Sampling temperature for text-model completion requests. Default 0 for deterministic normalization."
    },
    "TEXT_MODEL_ENDPOINT_POLICY_APPROVED": {
      "type": "boolean",
      "default": false,
      "$comment": "Explicit operator approval for the configured text-model endpoint profile. Selecting an endpoint alone does not approve redacted or customer routes."
    },
    "CUI_MODEL_BOUNDARY_APPROVED": {
      "type": "boolean",
      "default": false,
      "$comment": "Explicit operator approval for sending CUI-labeled package revisions to the configured text-model endpoint."
    },
    "VISION_MODEL_ENABLED": {
      "type": "boolean"
    },
    "VISION_MODEL_ENDPOINT_URL": {
      "$ref": "#/$defs/secureEndpointUrl"
    },
    "VISION_MODEL_NAME": {
      "$ref": "#/$defs/modelName"
    },
    "VISION_MODEL_CONTEXT_TOKENS": {
      "$ref": "#/$defs/positiveInteger"
    },
    "VISION_MODEL_ENDPOINT_PROFILE": {
      "$ref": "#/$defs/endpointProfile"
    },
    "VISION_MODEL_CREDENTIAL_REFERENCE": {
      "$ref": "#/$defs/credentialReference"
    },
    "MODEL_ENDPOINT_ALLOWLIST": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/allowedEndpoint"
      },
      "$comment": "Startup code must normalize each configured URL to its effective host and port, reject URL userinfo and redirects, resolve DNS safely, and require an exact allowlist match before any request. Semantic validation in runtime_config.py enforces userinfo rejection, production mock-profile rejection, allowlist matching, vision credential dependencies, and contradictory token limits without DNS or network calls."
    },
    "MAX_MODEL_CALLS_PER_RUN": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 120
    },
    "MAX_MODEL_INPUT_TOKENS_PER_RUN": {
      "$ref": "#/$defs/positiveInteger"
    },
    "MAX_MODEL_OUTPUT_TOKENS_PER_RUN": {
      "$ref": "#/$defs/positiveInteger"
    },
    "MAX_PACKAGE_BYTES": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 2147483648
    },
    "MAX_SINGLE_FILE_BYTES": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 104857600
    },
    "MAX_FILES_PER_REVISION": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 500
    },
    "MAX_ASSESSMENT_ITEMS": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 500
    },
    "MAX_EVIDENCE_ITEMS": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 2000
    },
    "MAX_PDF_PAGES_PER_FILE": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 200
    },
    "MAX_EXTRACTED_TEXT_CHARACTERS_PER_FILE": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 2000000
    },
    "MAX_ZIP_MEMBERS_PER_ARCHIVE": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 500
    },
    "MAX_ZIP_UNCOMPRESSED_BYTES_PER_ARCHIVE": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 104857600
    },
    "MAX_ZIP_DECOMPRESSION_RATIO": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 100
    },
    "MAX_XML_DEPTH": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 64
    },
    "MAX_XML_ELEMENTS": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 100000
    },
    "MAX_XML_ATTRIBUTES_PER_ELEMENT": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 128
    },
    "MAX_XML_TEXT_NODE_CHARACTERS": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 1048576
    },
    "MAX_CONCURRENT_ANALYSIS_RUNS": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2,
      "default": 2
    },
    "MAX_ACTIVE_ANALYZER_WORKERS": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2,
      "default": 2
    },
    "JOB_HEARTBEAT_SECONDS": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 30
    },
    "JOB_LEASE_SECONDS": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 300
    },
    "CHAT_MAX_RETRIEVED_CHUNKS": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8,
      "default": 8
    },
    "CHAT_RATE_LIMIT_PER_USER": {
      "$ref": "#/$defs/rateLimit"
    },
    "CHAT_INPUT_LIMIT": {
      "$ref": "#/$defs/measuredInputLimit"
    },
    "CHAT_TURN_LIMIT": {
      "$ref": "#/$defs/positiveInteger"
    },
    "CHAT_DAILY_TOKEN_LIMIT_PER_USER": {
      "$ref": "#/$defs/positiveInteger"
    },
    "STORAGE_DATA_PATH": {
      "$ref": "#/$defs/absolutePath"
    },
    "STORAGE_WARNING_PERCENT": {
      "const": 80
    },
    "STORAGE_REJECTION_PERCENT": {
      "const": 90
    },
    "DATABASE_ENGINE": {
      "const": "postgresql"
    },
    "DATABASE_MAJOR_VERSION": {
      "const": 16
    },
    "DATABASE_LISTEN_MODE": {
      "enum": [
        "loopback",
        "unix_socket"
      ]
    },
    "DATABASE_DSN_CREDENTIAL_REFERENCE": {
      "$ref": "#/$defs/credentialReference",
      "$comment": "Required for onprem_production. References a full SQLAlchemy PostgreSQL DSN supplied through systemd credentials or a root-owned file. The JSON document contains only the reference; startup code resolves it without logging the value."
    },
    "IDENTITY_PROVIDER_MODE": {
      "enum": [
        "oidc",
        "saml_identity_aware_proxy"
      ]
    },
    "OIDC_ISSUER_URL": {
      "$ref": "#/$defs/secureEndpointUrl"
    },
    "OIDC_AUDIENCE": {
      "$ref": "#/$defs/boundedText"
    },
    "PORTAL_PUBLIC_ORIGIN": {
      "$ref": "#/$defs/secureEndpointUrl",
      "$comment": "Browser origin serving the React portal. Used for CSRF Origin validation and OIDC redirect URIs."
    },
    "OIDC_CLIENT_CREDENTIAL_REFERENCE": {
      "$ref": "#/$defs/credentialReference"
    },
    "SAML_PROXY_TRUSTED_UPSTREAM_URL": {
      "$ref": "#/$defs/secureEndpointUrl"
    },
    "SAML_PROXY_AUTH_CREDENTIAL_REFERENCE": {
      "$ref": "#/$defs/credentialReference"
    },
    "SESSION_IDLE_TIMEOUT_MINUTES": {
      "const": 30
    },
    "SESSION_ABSOLUTE_TIMEOUT_HOURS": {
      "const": 8
    },
    "LOCAL_PASSWORD_AUTH_ENABLED": {
      "const": false
    },
    "MALWARE_SCANNER_ENABLED": {
      "const": true
    },
    "MALWARE_SCANNER_ID": {
      "$ref": "#/$defs/boundedIdentifier"
    },
    "MALWARE_SCANNER_FAILURE_POLICY": {
      "const": "fail_closed"
    },
    "MALWARE_SCANNER_TRANSPORT": {
      "type": "string",
      "enum": [
        "unix_socket",
        "tcp_loopback"
      ]
    },
    "MALWARE_SCANNER_SOCKET_PATH": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "MALWARE_SCANNER_HOST": {
      "type": "string",
      "minLength": 1,
      "maxLength": 253
    },
    "MALWARE_SCANNER_PORT": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "MALWARE_SCANNER_TIMEOUT_SECONDS": {
      "type": "integer",
      "minimum": 1,
      "maximum": 300,
      "default": 30
    },
    "RETENTION_YEARS": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 7,
      "$comment": "Seven years is the product default; an approved customer retention policy may configure another positive value."
    },
    "APPROVAL_EXPIRY_DAYS": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 7,
      "$comment": "Seven days after approval is the product default; a different value requires an approved customer policy."
    },
    "AUDIT_CHAIN_ALGORITHM": {
      "const": "HMAC-SHA-256"
    },
    "AUDIT_HMAC_KEY_CREDENTIAL_REFERENCE": {
      "$ref": "#/$defs/credentialReference"
    },
    "AUDIT_ROOT_BACKUP_FREQUENCY": {
      "const": "daily"
    },
    "BACKUP_RTO_HOURS": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 4,
      "default": 4
    },
    "BACKUP_RPO_HOURS": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 1,
      "default": 1
    },
    "BACKUP_POSTGRES_WAL_ARCHIVING_ENABLED": {
      "const": true
    },
    "BACKUP_FILESYSTEM_SNAPSHOT_INTERVAL_MINUTES": {
      "type": "integer",
      "minimum": 1,
      "maximum": 60,
      "default": 60
    },
    "BACKUP_FULL_FREQUENCY": {
      "const": "daily"
    },
    "BACKUP_OFF_HOST_ENABLED": {
      "const": true
    },
    "BACKUP_ENCRYPTION_ENABLED": {
      "const": true
    },
    "BACKUP_KEY_OWNERSHIP": {
      "const": "customer"
    },
    "BACKUP_ENCRYPTION_KEY_CREDENTIAL_REFERENCE": {
      "$ref": "#/$defs/credentialReference"
    },
    "BACKUP_ONLINE_RETENTION_DAYS": {
      "allOf": [
        {
          "$ref": "#/$defs/positiveInteger"
        }
      ],
      "default": 90
    },
    "BACKUP_RESTORE_DRILL_FREQUENCY": {
      "const": "quarterly"
    },
    "BACKUP_TARGET_DECLARATION": {
      "$ref": "#/$defs/backupTargetDeclaration",
      "$comment": "Customer backup destination declaration. Does not perform backup I/O; operator preflight validates syntax and allowlist membership only."
    },
    "OIDC_GROUPS_CLAIM": {
      "$ref": "#/$defs/boundedIdentifier",
      "default": "groups",
      "$comment": "JWT claim name containing group membership strings for RBAC mapping."
    },
    "OIDC_GROUP_ROLE_MAPPING": {
      "$ref": "#/$defs/oidcGroupRoleMapping"
    },
    "INTERNAL_EGRESS_ALLOWLIST": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/allowedEndpoint"
      },
      "$comment": "Closed outbound allowlist for IdP, model endpoints, and backup targets. Startup and operator preflight require configured endpoints to match entries exactly."
    },
    "AUTHORITY_MANIFEST_FILE_REFERENCE": {
      "$ref": "#/$defs/fileReferenceWithDigest",
      "$comment": "Optional override of the default authority manifest path with an expected SHA-256 digest."
    },
    "FISMA_TEMPLATE_PACK_FILE_REFERENCE": {
      "$ref": "#/$defs/fileReferenceWithDigest",
      "$comment": "Optional customer agency template pack path and digest when HS-002 inputs are supplied."
    },
    "PROCESS_CAPABILITIES": {
      "$ref": "#/$defs/processCapabilities"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "runtime_profile": {
            "const": "onprem_production"
          }
        },
        "required": [
          "runtime_profile"
        ]
      },
      "then": {
        "required": [
          "TEXT_MODEL_NAME",
          "TEXT_MODEL_CONTEXT_TOKENS",
          "TEXT_MODEL_MAX_OUTPUT_TOKENS",
          "TEXT_MODEL_TIMEOUT_SECONDS",
          "TEXT_MODEL_MAX_RETRIES",
          "TEXT_MODEL_ENDPOINT_PROFILE",
          "VISION_MODEL_ENABLED",
          "VISION_MODEL_ENDPOINT_URL",
          "VISION_MODEL_NAME",
          "VISION_MODEL_CONTEXT_TOKENS",
          "VISION_MODEL_ENDPOINT_PROFILE",
          "MODEL_ENDPOINT_ALLOWLIST",
          "MAX_MODEL_CALLS_PER_RUN",
          "MAX_MODEL_INPUT_TOKENS_PER_RUN",
          "MAX_MODEL_OUTPUT_TOKENS_PER_RUN",
          "MAX_PACKAGE_BYTES",
          "MAX_SINGLE_FILE_BYTES",
          "MAX_FILES_PER_REVISION",
          "MAX_ASSESSMENT_ITEMS",
          "MAX_EVIDENCE_ITEMS",
          "MAX_PDF_PAGES_PER_FILE",
          "MAX_EXTRACTED_TEXT_CHARACTERS_PER_FILE",
          "MAX_ZIP_MEMBERS_PER_ARCHIVE",
          "MAX_ZIP_UNCOMPRESSED_BYTES_PER_ARCHIVE",
          "MAX_ZIP_DECOMPRESSION_RATIO",
          "MAX_XML_DEPTH",
          "MAX_XML_ELEMENTS",
          "MAX_XML_ATTRIBUTES_PER_ELEMENT",
          "MAX_XML_TEXT_NODE_CHARACTERS",
          "MAX_CONCURRENT_ANALYSIS_RUNS",
          "MAX_ACTIVE_ANALYZER_WORKERS",
          "JOB_HEARTBEAT_SECONDS",
          "JOB_LEASE_SECONDS",
          "CHAT_MAX_RETRIEVED_CHUNKS",
          "CHAT_RATE_LIMIT_PER_USER",
          "CHAT_INPUT_LIMIT",
          "CHAT_TURN_LIMIT",
          "CHAT_DAILY_TOKEN_LIMIT_PER_USER",
          "STORAGE_DATA_PATH",
          "STORAGE_WARNING_PERCENT",
          "STORAGE_REJECTION_PERCENT",
          "DATABASE_ENGINE",
          "DATABASE_MAJOR_VERSION",
          "DATABASE_LISTEN_MODE",
          "DATABASE_DSN_CREDENTIAL_REFERENCE",
          "IDENTITY_PROVIDER_MODE",
          "SESSION_IDLE_TIMEOUT_MINUTES",
          "SESSION_ABSOLUTE_TIMEOUT_HOURS",
          "LOCAL_PASSWORD_AUTH_ENABLED",
          "MALWARE_SCANNER_ENABLED",
          "MALWARE_SCANNER_ID",
          "MALWARE_SCANNER_FAILURE_POLICY",
          "MALWARE_SCANNER_TRANSPORT",
          "MALWARE_SCANNER_TIMEOUT_SECONDS",
          "RETENTION_YEARS",
          "APPROVAL_EXPIRY_DAYS",
          "AUDIT_CHAIN_ALGORITHM",
          "AUDIT_HMAC_KEY_CREDENTIAL_REFERENCE",
          "AUDIT_ROOT_BACKUP_FREQUENCY",
          "BACKUP_RTO_HOURS",
          "BACKUP_RPO_HOURS",
          "BACKUP_POSTGRES_WAL_ARCHIVING_ENABLED",
          "BACKUP_FILESYSTEM_SNAPSHOT_INTERVAL_MINUTES",
          "BACKUP_FULL_FREQUENCY",
          "BACKUP_OFF_HOST_ENABLED",
          "BACKUP_ENCRYPTION_ENABLED",
          "BACKUP_KEY_OWNERSHIP",
          "BACKUP_ENCRYPTION_KEY_CREDENTIAL_REFERENCE",
          "BACKUP_ONLINE_RETENTION_DAYS",
          "BACKUP_RESTORE_DRILL_FREQUENCY",
          "BACKUP_TARGET_DECLARATION",
          "OIDC_GROUPS_CLAIM",
          "OIDC_GROUP_ROLE_MAPPING",
          "INTERNAL_EGRESS_ALLOWLIST",
          "AUTHORITY_MANIFEST_FILE_REFERENCE",
          "PROCESS_CAPABILITIES",
          "INSTALLATION_CUSTOMER_ENTERPRISE_ID"
        ],
        "properties": {
          "STORAGE_DATA_PATH": {
            "const": "/var/ato-packages"
          },
          "TEXT_MODEL_ENDPOINT_PROFILE": {
            "enum": [
              "external_openai",
              "internal_openai_compatible"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "runtime_profile": {
            "const": "onprem_production"
          },
          "MALWARE_SCANNER_TRANSPORT": {
            "const": "unix_socket"
          }
        },
        "required": [
          "runtime_profile",
          "MALWARE_SCANNER_TRANSPORT"
        ]
      },
      "then": {
        "required": [
          "MALWARE_SCANNER_SOCKET_PATH"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "runtime_profile": {
            "const": "onprem_production"
          },
          "MALWARE_SCANNER_TRANSPORT": {
            "const": "tcp_loopback"
          }
        },
        "required": [
          "runtime_profile",
          "MALWARE_SCANNER_TRANSPORT"
        ]
      },
      "then": {
        "required": [
          "MALWARE_SCANNER_HOST",
          "MALWARE_SCANNER_PORT"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "runtime_profile": {
            "const": "onprem_production"
          },
          "TEXT_MODEL_PROVIDER": {
            "const": "aws_bedrock"
          }
        },
        "required": [
          "runtime_profile",
          "TEXT_MODEL_PROVIDER"
        ]
      },
      "then": {
        "required": [
          "AWS_REGION"
        ]
      }
    },
    {
      "if": {
        "allOf": [
          {
            "properties": {
              "runtime_profile": {
                "const": "onprem_production"
              }
            },
            "required": [
              "runtime_profile"
            ]
          },
          {
            "anyOf": [
              {
                "not": {
                  "required": [
                    "TEXT_MODEL_PROVIDER"
                  ]
                }
              },
              {
                "properties": {
                  "TEXT_MODEL_PROVIDER": {
                    "const": "openai_compatible"
                  }
                },
                "required": [
                  "TEXT_MODEL_PROVIDER"
                ]
              }
            ]
          }
        ]
      },
      "then": {
        "required": [
          "TEXT_MODEL_ENDPOINT_URL"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "TEXT_MODEL_PROVIDER": {
            "const": "aws_bedrock"
          }
        },
        "required": [
          "TEXT_MODEL_PROVIDER"
        ]
      },
      "then": {
        "required": [
          "AWS_REGION",
          "TEXT_MODEL_NAME",
          "TEXT_MODEL_MAX_OUTPUT_TOKENS",
          "TEXT_MODEL_TIMEOUT_SECONDS"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "TEXT_MODEL_ENDPOINT_URL": {
            "pattern": "^http://"
          }
        },
        "required": [
          "TEXT_MODEL_ENDPOINT_URL"
        ]
      },
      "then": {
        "required": [
          "ALLOW_LOOPBACK_HTTP_INTERNAL_ENDPOINTS",
          "TEXT_MODEL_ENDPOINT_PROFILE"
        ],
        "properties": {
          "ALLOW_LOOPBACK_HTTP_INTERNAL_ENDPOINTS": {
            "const": true
          },
          "TEXT_MODEL_ENDPOINT_PROFILE": {
            "const": "internal_openai_compatible"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "TEXT_MODEL_NAME",
          "TEXT_MODEL_ENDPOINT_URL"
        ],
        "properties": {
          "TEXT_MODEL_NAME": {
            "type": "string",
            "minLength": 1
          },
          "TEXT_MODEL_ENDPOINT_URL": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "then": {
        "required": [
          "TEXT_MODEL_ENDPOINT_PROFILE"
        ],
        "properties": {
          "TEXT_MODEL_ENDPOINT_PROFILE": {
            "not": {
              "const": "mock"
            }
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "TEXT_MODEL_NAME",
          "TEXT_MODEL_PROVIDER",
          "AWS_REGION"
        ],
        "properties": {
          "TEXT_MODEL_PROVIDER": {
            "const": "aws_bedrock"
          },
          "TEXT_MODEL_NAME": {
            "type": "string",
            "minLength": 1
          },
          "AWS_REGION": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "then": {
        "required": [
