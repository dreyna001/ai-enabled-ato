  "$defs": {
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "boundedText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^[^\\u0000-\\u001F\\u007F]+$"
    },
    "boundedIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "modelName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"
    },
    "endpointProfile": {
      "enum": [
        "mock",
        "external_openai",
        "internal_openai_compatible"
      ]
    },
    "secureEndpointUrl": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "oneOf": [
        {
          "format": "uri",
          "pattern": "^https://[^\\s]+$"
        },
        {
          "format": "uri",
          "pattern": "^http://(?:localhost|127(?:\\.(?:25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})){3}|\\[::1\\])(?::[0-9]{1,5})?(?:/[^\\s]*)?$"
        }
      ],
      "$comment": "Schema syntax permits HTTPS or literal loopback HTTP only. Startup code must reject userinfo, fragments where inappropriate, invalid or implicit disallowed ports, redirects, non-loopback DNS results, DNS rebinding, and any host/port outside the deployment allowlist."
    },
    "absolutePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^/(?:[A-Za-z0-9._-]+/)*[A-Za-z0-9._-]+$",
      "$comment": "Startup code must resolve and normalize the path without following unsafe links and must verify required ownership, mode, mount, capacity, and containment properties."
    },
    "credentialReference": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "identifier"
          ],
          "properties": {
            "source": {
              "const": "systemd_credential"
            },
            "identifier": {
              "$ref": "#/$defs/boundedIdentifier"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "path"
          ],
          "properties": {
            "source": {
              "const": "root_owned_file"
            },
            "path": {
              "$ref": "#/$defs/absolutePath"
            }
          }
        }
      ],
      "$comment": "Only a reference is valid here. Startup code must resolve it without logging the value and verify that file-backed credentials are root-owned with mode 0640 or stricter."
    },
    "allowedEndpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "host",
        "port"
      ],
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1,
          "maxLength": 253,
          "oneOf": [
            {
              "pattern": "^[A-Za-z0-9][A-Za-z0-9.-]*$"
            },
            {
              "pattern": "^[0-9A-Fa-f:]*:[0-9A-Fa-f:.]*$"
            }
          ]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "$comment": "Startup code must canonicalize DNS names and IP literals and compare the URL's effective host and port exactly; this syntax check is not DNS or SSRF validation."
    },
    "rateLimit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_requests",
        "window_seconds"
      ],
      "properties": {
        "max_requests": {
          "$ref": "#/$defs/positiveInteger"
        },
        "window_seconds": {
          "$ref": "#/$defs/positiveInteger"
        }
      }
    },
    "measuredInputLimit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "unit"
      ],
      "properties": {
        "value": {
          "$ref": "#/$defs/positiveInteger"
        },
        "unit": {
          "enum": [
            "characters",
            "tokens"
          ]
        }
      },
      "$comment": "The specification requires a configurable input-length limit but does not prescribe its value or measurement unit; the deployment must choose and enforce one explicitly."
    },
    "groupNameList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/boundedText"
      }
    },
    "oidcGroupRoleMapping": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "system_owner": {
          "$ref": "#/$defs/groupNameList"
        },
        "isso": {
          "$ref": "#/$defs/groupNameList"
        },
        "control_owner": {
          "$ref": "#/$defs/groupNameList"
        },
        "assessor": {
          "$ref": "#/$defs/groupNameList"
        },
        "reviewer": {
          "$ref": "#/$defs/groupNameList"
        },
        "approver": {
          "$ref": "#/$defs/groupNameList"
        },
        "ao_custodian": {
          "$ref": "#/$defs/groupNameList"
        },
        "viewer": {
          "$ref": "#/$defs/groupNameList"
        },
        "platform_admin": {
          "$ref": "#/$defs/groupNameList"
        }
      },
      "$comment": "Maps product roles to one or more IdP group names resolved from OIDC_GROUPS_CLAIM."
    },
    "fileReferenceWithDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "expected_sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/absolutePath"
        },
        "expected_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "backupTargetDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol",
        "host",
        "port",
        "export_path"
      ],
      "properties": {
        "protocol": {
          "enum": [
            "nfs_v4",
            "smb",
            "s3_compatible",
            "local_mount"
          ]
        },
        "host": {
          "type": "string",
          "minLength": 1,
          "maxLength": 253
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "export_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024,
          "pattern": "^/[^\\u0000-\\u001F\\u007F]+$"
        }
      }
    },
    "processCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "api",
        "intake_worker",
        "analyzer_worker",
        "portal_static",
        "malware_scanning",
        "text_model_calls",
        "vision_model_calls",
        "oidc_authentication"
      ],
      "properties": {
        "api": {
          "type": "boolean"
        },
        "intake_worker": {
          "type": "boolean"
        },
        "analyzer_worker": {
          "type": "boolean"
        },
        "portal_static": {
          "type": "boolean"
        },
        "malware_scanning": {
          "type": "boolean"
        },
        "text_model_calls": {
          "type": "boolean"
        },
        "vision_model_calls": {
          "type": "boolean"
        },
        "oidc_authentication": {
          "type": "boolean"
        },
        "package_search": {
          "type": "boolean",
          "default": false
        },
        "package_chat": {
          "type": "boolean",
          "default": false
        }
      },
      "$comment": "Explicit process and feature flags. Inactive optional capabilities are ignored by operator preflight; active capabilities fail fast when dependencies are invalid."
    }
  }
}
