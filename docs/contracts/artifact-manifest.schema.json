{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ato.local/schemas/artifact-manifest.schema.json",
  "title": "ATO Run Artifact Manifest",
  "$comment": "Semantic validation MUST recompute every generated file SHA-256 and size, reject duplicate paths, and verify that the recorded authority, analysis profile, configuration, prompt bundle, and package revision are the immutable inputs used by the run. artifact-manifest.json is not a member of files: it MUST be fsynced and written last, after every listed file is durable, and the run MUST be marked succeeded only after manifest durability and database commit.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "package_revision_id",
    "authority_manifest_id",
    "analysis_profile_sha256",
    "config_fingerprint",
    "prompt_bundle_sha256",
    "completed_at",
    "files"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "run_id": {
      "$ref": "#/$defs/uuidV4"
    },
    "package_revision_id": {
      "$ref": "#/$defs/uuidV4"
    },
    "authority_manifest_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$",
      "maxLength": 128
    },
    "analysis_profile_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "config_fingerprint": {
      "$ref": "#/$defs/sha256"
    },
    "prompt_bundle_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "completed_at": {
      "$ref": "#/$defs/utcDateTime"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/generatedFile"
      }
    }
  },
  "$defs": {
    "uuidV4": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "utcDateTime": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "generatedFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "size_bytes"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?:human|machine|provenance|validation)/(?!\\.\\.?/)(?!.*(?:/\\.\\.?/|/\\.\\.?$))(?!.*//)[A-Za-z0-9](?:[A-Za-z0-9._/-]{0,502}[A-Za-z0-9])?$",
          "maxLength": 512
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
