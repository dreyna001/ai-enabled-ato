{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ato.local/schemas/sufficiency-matrix-response.schema.json",
  "title": "Sufficiency Matrix Model Response",
  "$comment": "Closed structured output for sufficiency_matrix v1. Matrix row identifiers and run bindings are assigned by deterministic validators after parsing.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "rows"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "$ref": "#/$defs/MatrixRowProposal"
      }
    }
  },
  "$defs": {
    "MatrixRowProposal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assessment_item_id",
        "model_proposed_status",
        "finding_summary",
        "gaps",
        "assessor_questions",
        "citations",
        "context_complete"
      ],
      "properties": {
        "assessment_item_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9()._-]{1,127}$"
        },
        "model_proposed_status": {
          "enum": [
            "supported",
            "partial",
            "unsupported",
            "insufficient_evidence"
          ]
        },
        "finding_summary": {
          "type": "string",
          "maxLength": 4000
        },
        "gaps": {
          "type": "array",
          "maxItems": 50,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          }
        },
        "assessor_questions": {
          "type": "array",
          "maxItems": 50,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          }
        },
        "citations": {
          "type": "array",
          "maxItems": 100,
          "items": {
            "$ref": "#/$defs/CitationProposal"
          }
        },
        "context_complete": {
          "type": "boolean"
        }
      }
    },
    "CitationProposal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_kind",
        "source_id",
        "source_sha256",
        "start_offset",
        "end_offset"
      ],
      "properties": {
        "source_kind": {
          "enum": [
            "evidence",
            "authoritative_reference",
            "derived_inference"
          ]
        },
        "source_id": {
          "type": "string",
          "format": "uuid"
        },
        "source_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "chunk_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        },
        "start_offset": {
          "type": "integer",
          "minimum": 0
        },
        "end_offset": {
          "type": "integer",
          "minimum": 1
        },
        "page_or_section": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 500
        }
      }
    }
  }
}
