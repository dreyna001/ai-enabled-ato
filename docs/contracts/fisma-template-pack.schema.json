{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ato.local/schemas/fisma-template-pack.schema.json",
  "title": "ATO Agency FISMA Template Pack Manifest",
  "$comment": "Manifest bytes live inside a digest-verified ZIP archive referenced by runtime JSON FISMA_TEMPLATE_PACK_FILE_REFERENCE. The product validates archive members and mappings but never overwrites customer templates or infers agency-specific required fields.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "pack_version",
    "approval_status",
    "required_members",
    "field_mappings",
    "artifact_templates"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$",
      "maxLength": 128
    },
    "pack_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "maxLength": 32
    },
    "approval_status": {
      "enum": [
        "approved",
        "pending",
        "rejected"
      ]
    },
    "description": {
      "type": "string",
      "maxLength": 2000
    },
    "required_members": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512,
        "pattern": "^(?!\\.\\.?/)(?!.*(?:/\\.\\.?/|/\\.\\.?$))(?!.*//)[A-Za-z0-9][A-Za-z0-9._/-]*$"
      }
    },
    "field_mappings": {
      "type": "array",
      "maxItems": 2048,
      "items": {
        "$ref": "#/$defs/fieldMapping"
      }
    },
    "artifact_templates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "$ref": "#/$defs/artifactTemplate"
      }
    }
  },
  "$defs": {
    "fieldMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mapping_id",
        "source_pointer",
        "target_artifact",
        "target_field"
      ],
      "properties": {
        "mapping_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$",
          "maxLength": 128
        },
        "source_pointer": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000,
          "pattern": "^(/([^~/]|~[01])*)+$"
        },
        "target_artifact": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$",
          "maxLength": 128
        },
        "target_field": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{0,127}$",
          "maxLength": 128
        }
      }
    },
    "artifactTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "export_paths"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$",
          "maxLength": 128
        },
        "human_template_member": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^(?!\\.\\.?/)(?!.*(?:/\\.\\.?/|/\\.\\.?$))(?!.*//)[A-Za-z0-9][A-Za-z0-9._/-]*$"
        },
        "machine_schema_member": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^(?!\\.\\.?/)(?!.*(?:/\\.\\.?/|/\\.\\.?$))(?!.*//)[A-Za-z0-9][A-Za-z0-9._/-]*$"
        },
        "export_paths": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "human",
            "machine"
          ],
          "properties": {
            "human": {
              "type": "string",
              "pattern": "^human/[A-Za-z0-9][A-Za-z0-9._/-]*\\.(md|txt)$"
            },
            "machine": {
              "type": "string",
              "pattern": "^machine/[A-Za-z0-9][A-Za-z0-9._/-]*\\.json$"
            }
          }
        }
      }
    }
  }
}
