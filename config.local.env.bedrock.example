# Copy to config.local.env (gitignored) for WSL portal enable with Bedrock.
# The API service runs as user 'ato' with ProtectHome=yes, so AWS credentials
# must be installed via wsl-portal-enable.sh into ato-local.env (not ~/.aws).
# Do not commit config.local.env.

# Use AWS_PROFILE or standard AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY lines.
AWS_PROFILE=your-aws-profile
